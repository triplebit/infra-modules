# Managed by Ansible (github_runner role) — secrets from sops.
# Loaded into the runner's process environment: jobs can read everything
# here BY DESIGN (credentials-on-runner model). The GitHub App key is NOT
# here — it lives in app.pem, readable only by the root mint stage.

# --- runner registration (read by mint-jit.sh) ---
# Repo-level registration: the runner is usable only by this one repo.
GITHUB_ORG={{ github_runner_org }}
GITHUB_REPO={{ github_runner_repo }}
GITHUB_APP_CLIENT_ID={{ github_runner_app_client_id }}
RUNNER_LABELS={{ github_runner_labels }}

# --- job-facing deploy credentials ---
{% for k, v in github_runner_job_env.items() %}
{{ k }}={{ v }}
{% endfor %}
